# Copy to .env and adjust as needed. Defaults work for local docker-compose.

# --- MinIO (distributed object store / data lake) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ENDPOINT_HOST=http://localhost:9000   # used from the host (scrapers run on host)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobmarket

# --- MongoDB (raw, schema-on-read store) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=jobmarket
MONGO_COLLECTION=raw_postings

# --- PostgreSQL (serving / gold marts) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jobmarket
POSTGRES_USER=jobmarket
POSTGRES_PASSWORD=jobmarket

# --- Scraper politeness knobs (data ethics) ---
SCRAPE_DELAY_SECONDS=2.5     # min delay between requests to the same host
SCRAPE_MAX_RECORDS=1500      # hard daily cap
SCRAPE_USER_AGENT=BDA-FinalProject-Academic/1.0 (+https://github.com/r14922128; NTU coursework; contact r14922128@csie.ntu.edu.tw)
